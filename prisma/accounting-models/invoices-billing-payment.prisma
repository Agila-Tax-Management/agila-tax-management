enum InvoiceStatus {
    DRAFT
    UNPAID
    PARTIALLY_PAID
    PAID
    OVERDUE
    VOID
}

enum PaymentMethod {
    CASH
    BANK_TRANSFER
    CHECK
    E_WALLET
    CREDIT_CARD
}

enum PaymentChangeType {
    PAYMENT_RECORDED
    PAYMENT_UPDATED
    ALLOCATION_MODIFIED
    STATUS_CHANGED // E.g., if a check clears or bounces
    PAYMENT_VOIDED
}

enum InvoiceChangeType {
    INVOICE_CREATED
    INVOICE_UPDATED
    STATUS_CHANGED
    DUE_DATE_CHANGED
    PAYMENT_ADDED
    PAYMENT_VOIDED
    ITEM_ADDED
    ITEM_REMOVED
    INVOICE_VOIDED
}

enum SubscriptionChangeType {
    SUBSCRIPTION_CREATED
    RATE_CHANGED
    PLAN_CHANGED
    PAUSED
    REACTIVATED
    CANCELLED
}

enum BillingCycle {
    MONTHLY
    QUARTERLY
    SEMI_ANNUALLY
    ANNUALLY
}

// ─── Client Service Subscription (Replaces acs_client_service_plan)
// Tracks the active recurring plans a client has agreed to.
// Tracks the active recurring plans a client has agreed to.
model ClientSubscription {
    id Int @id @default(autoincrement())

    clientId Int
    client   Client @relation(fields: [clientId], references: [id])

    // ─── UPDATED: Links to the Unified Service Catalog ───
    serviceId Int
    service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

    // ─── NEW: Audit Trail back to Sales ───
    // Which negotiated quote generated this subscription?
    quoteLineItemId String?        @unique
    quoteLineItem   QuoteLineItem? @relation(fields: [quoteLineItemId], references: [id], onDelete: SetNull)

    invoiceItems InvoiceItem[]

    // ─── Automation Triggers ───
    billingCycle    BillingCycle @default(MONTHLY)
    nextBillingDate DateTime?

    agreedRate    Decimal   @db.Decimal(10, 2)
    effectiveDate DateTime
    inactiveDate  DateTime?

    isActive Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    historyLogs SubscriptionHistory[]

    @@index([clientId, isActive])
    @@index([nextBillingDate])
    @@map("client_subscription")
}

// ─── Invoice (Replaces acs_invoices & acs_billing) ────────────────
model Invoice {
    id            String @id @default(cuid())
    invoiceNumber String @unique // e.g., "INV-2026-0001"

    // Can belong to an active Client OR an onboarding Lead
    clientId Int?
    client   Client? @relation(fields: [clientId], references: [id])
    leadId   Int?
    lead     Lead?   @relation(fields: [leadId], references: [id])

    status InvoiceStatus @default(UNPAID)

    issueDate DateTime @default(now())
    dueDate   DateTime

    // Financial Totals
    subTotal       Decimal @default(0.00) @db.Decimal(10, 2)
    taxAmount      Decimal @default(0.00) @db.Decimal(10, 2)
    discountAmount Decimal @default(0.00) @db.Decimal(10, 2)
    totalAmount    Decimal @default(0.00) @db.Decimal(10, 2)
    balanceDue     Decimal @default(0.00) @db.Decimal(10, 2)

    notes String? @db.Text
    terms String? @db.Text // "Net 15", "Net 30"

    items       InvoiceItem[]
    allocations PaymentAllocation[]
    historyLogs InvoiceHistory[]

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    payments  Payment[]

    @@index([clientId])
    @@index([leadId])
    @@index([status])
    @@map("invoice")
}

// ─── Invoice Item (Snapshot of the service rendered) ──────────────
model InvoiceItem {
    id Int @id @default(autoincrement())

    invoiceId String
    invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

    // ─── OPTIONAL ADDITION: Track revenue back to the subscription ───
    // If this item was auto-generated by a recurring plan, link it here.
    // If it was a one-time manual invoice, this remains null.
    subscriptionId Int?
    subscription   ClientSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

    // NO FOREIGN KEYS TO SERVICES. This is a hardcoded snapshot.
    description String // e.g., "Monthly Bookkeeping - March 2026"
    quantity    Int     @default(1)
    unitPrice   Decimal @db.Decimal(10, 2)
    total       Decimal @db.Decimal(10, 2)

    isVatable Boolean @default(true)

    remarks String? @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([invoiceId])
    @@index([subscriptionId])
    @@map("invoice_item")
}

// ─── Payment (Replaces acs_payment_system) ────────────────────────
model Payment {
    id String @id @default(cuid())

    paymentNumber String @unique // ADD THIS: e.g., "PAY-2026-0001"

    // ─── Which Client & Invoice does this payment belong to? ───
    clientId Int?
    client   Client? @relation(fields: [clientId], references: [id])

    // Track exactly who recorded this payment (Internal ERP Staff)
    recordedById String?
    recordedBy   User?   @relation(fields: [recordedById], references: [id])

    amount      Decimal       @db.Decimal(10, 2)
    paymentDate DateTime      @default(now())
    method      PaymentMethod

    // Crucial for tracking if there is leftover money (e.g., they overpaid)
    unusedAmount Decimal @default(0) @db.Decimal(10, 2)

    referenceNumber   String? // e.g., Bank Transfer Ref # or Check #
    proofOfPaymentUrl String? // URL to the uploaded deposit slip/screenshot

    notes String? @db.Text

    // The Bridge connections
    allocations PaymentAllocation[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    invoice   Invoice? @relation(fields: [invoiceId], references: [id])
    invoiceId String?

    historyLogs PaymentHistory[]

    @@index([clientId])
    @@map("payment")
}

model PaymentAllocation {
    id String @id @default(cuid())

    // Which Payment is this cash coming from?
    paymentId String
    payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

    // Which Invoice is this cash paying down?
    invoiceId String
    invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

    // How much of the payment was applied to this specific invoice?
    amountApplied Decimal @db.Decimal(10, 2)

    createdAt DateTime @default(now())

    @@index([paymentId])
    @@index([invoiceId])
    @@map("payment_allocation")
}

// ─── Payment History (Audit Trail) ────────────────────────────────
model PaymentHistory {
    id String @id @default(cuid())

    paymentId String
    payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

    // The internal ERP user who made the change
    actorId String?
    actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

    changeType PaymentChangeType

    // Text snapshots (e.g., oldValue: "Amount: 20000", newValue: "Amount: 2000")
    oldValue String? @db.Text
    newValue String? @db.Text

    createdAt DateTime @default(now())

    @@index([paymentId])
    @@index([paymentId, createdAt(sort: Desc)])
    @@map("payment_history")
}

// ─── Invoice History (Audit Trail) ────────────────────────────────
model InvoiceHistory {
    id String @id @default(cuid())

    invoiceId String
    invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

    // The internal ERP user who made the change (or "SYSTEM" if done by a cron job)
    actorId String?
    actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

    changeType InvoiceChangeType

    // Text snapshots (e.g., oldValue: "UNPAID", newValue: "PARTIALLY_PAID")
    oldValue String? @db.Text
    newValue String? @db.Text

    createdAt DateTime @default(now())

    @@index([invoiceId])
    @@index([invoiceId, createdAt(sort: Desc)])
    @@map("invoice_history")
}

// ─── Subscription History (Audit Trail) ───────────────────────────
model SubscriptionHistory {
    id String @id @default(cuid())

    subscriptionId Int
    subscription   ClientSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

    actorId String?
    actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

    changeType SubscriptionChangeType

    // Text snapshots (e.g., oldValue: "5000.00", newValue: "6000.00")
    oldValue String? @db.Text
    newValue String? @db.Text

    createdAt DateTime @default(now())

    @@index([subscriptionId])
    @@index([subscriptionId, createdAt(sort: Desc)])
    @@map("subscription_history")
}
