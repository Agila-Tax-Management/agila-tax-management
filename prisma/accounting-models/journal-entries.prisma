// prisma/accounting-models/journal-entries.prisma

enum JournalTransactionType {
  JOURNAL_ENTRY
  INVOICE
  PAYMENT
  EXPENSE
  RECEIPT
  PETTY_CASH   // Petty cash disbursement journal entry
  CLIENT_FUND  // Client fund adjustment journal entry
}

enum JournalEntryStatus {
  DRAFT
  POSTED
}

// ─── Journal Entry (Header) ───────────────────────────────────────
model JournalEntry {
  id              String                 @id @default(cuid())
  referenceNo     String                 @unique
  transactionDate DateTime               @db.Date
  transactionType JournalTransactionType @default(JOURNAL_ENTRY)
  status          JournalEntryStatus     @default(DRAFT)
  notes           String?                @db.Text
  attachments     String[]               @default([])

  // Optional client linkage (not enforced as a Prisma FK to avoid schema coupling)
  clientId Int?

  // Tracks who created the entry (stored as string, not enforced FK)
  createdById String?

  lines JournalLine[]

  // ─── Linked compliance transaction records ───
  salesRecords   SalesRecord[]
  expenseRecords ExpenseRecord[]
  invoices       Invoice[]

  // ─── Linked accounting transaction records ───
  payments               Payment[]
  pettyCashes            PettyCash[]
  clientFundTransactions ClientFundTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionDate])
  @@index([clientId])
  @@index([status])
  @@map("journal_entry")
}

// ─── Journal Line (Each debit/credit row) ────────────────────────
model JournalLine {
  id String @id @default(cuid())

  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  glAccountId String
  glAccount   GlAccount @relation(fields: [glAccountId], references: [id], onDelete: Restrict)

  debit       Decimal? @db.Decimal(15, 2)
  credit      Decimal? @db.Decimal(15, 2)
  description String?
  name        String?
  sortOrder   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([journalEntryId])
  @@index([glAccountId])
  @@map("journal_line")
}
