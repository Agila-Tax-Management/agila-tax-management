enum NotificationType {
    INFO
    SUCCESS
    WARNING
    ERROR
    ACTION_REQUIRED
}

enum NotificationPriority {
    LOW
    NORMAL
    HIGH
    URGENT
}

model InternalNotification {
    id String @id @default(cuid())

    /// The user who receives this notification
    recipientId String
    recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

    /// The user whose action triggered this notification (nullable for system-generated)
    actorId String?
    actor   User?  @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

    type     NotificationType     @default(INFO)
    priority NotificationPriority @default(NORMAL)

    /// Short title shown in the notification list
    title String

    /// Detailed message body
    message String

    /// The entity type this notification relates to (e.g. "Client", "Lead")
    entity String?

    /// The primary key of the related record — for building deep links
    entityId String?

    /// Optional URL path to navigate to when clicked
    actionUrl String?

    isRead Boolean @default(false)
    readAt DateTime?

    createdAt DateTime @default(now())

    @@index([recipientId, isRead])
    @@index([recipientId, createdAt])
    @@index([actorId])
    @@map("internal_notification")
}
