enum ClientUserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ClientPortalRole {
  OWNER
  ADMIN
  EMPLOYEE
  VIEWER
}

enum BusinessType {
  INDIVIDUAL
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  CORPORATION
  COOPERATIVE
}

model Client {
  id Int @id @default(autoincrement())

  companyCode String? @unique
  clientNo    String?

  active Boolean @default(false)

  businessType BusinessType?

  businessCategoryId Int?
  businessCategory   BusinessCategory? @relation(fields: [businessCategoryId], references: [id])

  portalName   String?
  businessName String?

  branchType String?

  mainBranchId Int?
  mainBranch   Client?  @relation("BranchRelation", fields: [mainBranchId], references: [id])
  branches     Client[] @relation("BranchRelation")

  logo String?

  clientIpAddress String?

  dayResetTime     DateTime? @db.Time
  workingDayStarts DateTime? @db.Time

  timezone String? @default("Asia/Manila")

  lead            Lead?

  clientUsers     ClientUser[]
  userAssignments ClientUserAssignment[]

  professionalProfiles ProfessionalClient[]
  soleProprietorships  SoleProprietorship[]

  departments    Department[]
  teams          EmployeeTeam[]
  employments    EmployeeEmployment[]
  workSchedules  WorkSchedule[]
  employeeLevels EmployeeLevel[]
  tasks          Task[]

  subscriptions ClientSubscription[]
  invoices      Invoice[]
  cashAdvances          CashAdvance[]

  holidays         Holiday[]
  timesheets       Timesheet[]
  overtimeRequests OvertimeRequest[]
  leaveTypes       LeaveType[]
  leaveRequests    LeaveRequest[]
  payrollPeriods   PayrollPeriod[]

  createdAt DateTime? @map("created_at")

  @@map("atms_clients")
}

model BusinessCategory {
  id Int @id @default(autoincrement())

  name String @unique

  clients Client[]

  createdAt DateTime @default(now())
}

model ClientUser {
  id String @id @default(cuid())

  name          String?
  email         String           @unique
  emailVerified Boolean          @default(false)
  image         String?
  active        Boolean          @default(true)
  status        ClientUserStatus @default(ACTIVE)

  // Legacy single-client FK kept for BetterAuth additionalFields compatibility
  clientId Int?
  client   Client? @relation(fields: [clientId], references: [id])

  assignments ClientUserAssignment[]
  employee    Employee?
  sessions    ClientSession[]
  accounts    ClientAccount[]

  overtimesApproved    OvertimeRequest[] @relation("ClientOvertimeApprover")
  leavesApproved       LeaveRequest[]    @relation("ClientLeaveApprover")
  payslipsApproved     Payslip[]         @relation("ClientPayslipApprover")
  payslipsAcknowledged Payslip[]         @relation("ClientPayslipAcknowledger")
  cashAdvancesApproved  CashAdvance[] @relation("ClientCashAdvanceApprover")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_user")
}

// ─── Client ↔ ClientUser Join Table ──────────────────────────────
model ClientUserAssignment {
  id Int @id @default(autoincrement())

  clientUserId String
  clientUser   ClientUser @relation(fields: [clientUserId], references: [id], onDelete: Cascade)

  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  role ClientPortalRole @default(EMPLOYEE)

  createdAt DateTime @default(now())

  @@unique([clientUserId, clientId])
  @@map("client_user_assignment")
}

model ProfessionalClient {
  id Int @id @default(autoincrement())

  clientId Int
  client   Client @relation(fields: [clientId], references: [id])

  firstName  String?
  middleName String?
  lastName   String?

  residentialAddress String?

  businessType String?
  tradeName    String?

  civilStatus String?

  dateOfBirth DateTime?
  age         Int?

  gender String?

  tinNumber String?

  citizenship  String?
  placeOfBirth String?

  prcLicense String?

  contactNumber String?
  contactEmail  String?
  contactPerson String?

  idType   String?
  idNumber String?

  spouseTinNumber    String?
  spouseEmployerName String?
  spouseEmployerTin  String?

  spouseFirstName  String?
  spouseMiddleName String?
  spouseLastName   String?

  spouseEmploymentStatus String?

  motherFirstName  String?
  motherMiddleName String?
  motherLastName   String?

  fatherFirstName  String?
  fatherMiddleName String?
  fatherLastName   String?

  createdAt DateTime @default(now())

  @@map("atms_professional")
}

model SoleProprietorship {
  id Int @id @default(autoincrement())

  clientId Int
  client   Client @relation(fields: [clientId], references: [id])

  businessName String?

  firstName  String?
  middleName String?
  lastName   String?

  residentialAddress String?
  businessAddress    String?

  businessType String?
  tradeName    String?

  civilStatus String?

  dateOfBirth DateTime?
  age         Int?

  gender String?

  tinNumber String?

  citizenship  String?
  placeOfBirth String?

  businessArea      String?
  numberOfEmployees Int?

  beginningCapital String?

  landlineNumber String?
  faxNumber      String?

  motherFirstName  String?
  motherMiddleName String?
  motherLastName   String?

  fatherFirstName  String?
  fatherMiddleName String?
  fatherLastName   String?

  spouseFirstName  String?
  spouseMiddleName String?
  spouseLastName   String?

  spouseEmploymentStatus String?
  spouseTinNumber        String?
  spouseEmployerName     String?
  spouseEmployerTin      String?

  businessPlace String?

  ownedDocs   String?
  ownedReason String?

  rentedContract      String?
  rentedNotarized     String?
  rentedDocStamp      String?
  rentedMonthlyRent   String?
  rentedLessorName    String?
  rentedLessorAddress String?

  propertyOwner String?

  noRentReason String?

  landlordOwnDocs   String?
  landlordOwnReason String?

  landlordLeaseDocs   String?
  landlordLeaseReason String?

  contactPerson String?
  contactEmail  String?
  contactNumber String?

  idType   String?
  idNumber String?

  createdAt DateTime @default(now())

  @@map("atms_sole_proprietorship")
}
