enum ClientUserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ClientPortalRole {
  OWNER
  ADMIN
  EMPLOYEE
  VIEWER
}

enum BusinessEntity {
  INDIVIDUAL
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  CORPORATION
  COOPERATIVE
}

enum BranchType {
  MAIN
  BRANCH
}

enum PlaceType {
  OWNED
  RENTED
  FREE_USE // e.g., using a relative's property for free
}

model Client {
  id          Int     @id @default(autoincrement())
  companyCode String? @unique // e.g., "COMP-001" this will base on the name like "Acme Corporation" -> "ACME-001" so 4 letters + 3-digit sequence incremental the "001" is their main branch, if they have branches it will be "ACME-002", "ACME-003" and so on. This is for internal use and can be used in URLs or references instead of the numeric ID.
  clientNo    String? @unique // e.g., "2024-0001"

  portalName   String // Used for their BetterAuth login portal URL
  businessName String // Official registered name
  logoUrl      String?

  businessEntity BusinessEntity
  branchType     BranchType     @default(MAIN)

  // ─── Self-Relation for Head Office vs Branches ───
  mainBranchId Int?
  mainBranch   Client?  @relation("BranchToMain", fields: [mainBranchId], references: [id])
  branches     Client[] @relation("BranchToMain")

  active Boolean @default(false)

  // The Client Relation Officer (Handles client communications, onboarding, and overall relationship management)
  clientRelationOfficerId String?
  clientRelationOfficer   User?   @relation("ClientRelationOfficer", fields: [clientRelationOfficerId], references: [id])

  // The Operations Manager (Oversees bookkeeping, HR, and tax compliance execution)
  operationsManagerId String?
  operationsManager   User?   @relation("OperationsManager", fields: [operationsManagerId], references: [id])

  // ─── Timekeeping & SLA Defaults ───
  dayResetTime     String @default("00:00:00") // When the system flips to "tomorrow"
  workingDayStarts String @default("09:00:00") // Default opening hour
  timezone         String @default("Asia/Manila")

  // ─── 1-to-1 Tax & Compliance Profiles ───
  birInfo           BirInformation?
  businessDetails   BusinessOperations?
  corporateDetails  CorporateDetails?
  individualDetails IndividualDetails?

  // 1-to-Many
  shareholders CorporateShareholder[]

  lead Lead?
  jobOrders   JobOrder[]
  tsaContracts TsaContract[]

  activityLogs ActivityLog[]

  clientUsers     ClientUser[]
  userAssignments ClientUserAssignment[]

  departments    Department[]
  teams          EmployeeTeam[]
  employments    EmployeeEmployment[]
  workSchedules  WorkSchedule[]
  employeeLevels EmployeeLevel[]
  tasks          Task[]

  subscriptions ClientSubscription[]
  invoices      Invoice[]
  payments      Payment[]
  cashAdvances  CashAdvance[]

  hrSetting         HrSetting?

  payrollSchedules  PayrollSchedule[]

  holidays         Holiday[]
  timesheets       Timesheet[]
  overtimeRequests OvertimeRequest[]
  coaRequests      CoaRequest[]
  leaveTypes       LeaveType[]
  leaveRequests    LeaveRequest[]
  payrollPeriods   PayrollPeriod[]
  governmentLoans  GovernmentLoan[]

  //Compliances
  compliances ClientCompliance[]

  glAccounts GlAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("atms_clients")
}

// ─── BIR Information (Form 2303 / COR Details) ────────────────────
model BirInformation {
  id Int @id @default(autoincrement())

  clientId Int    @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tin        String // 9-digit TIN
  branchCode String @default("0000") // Last 3-4 digits
  rdoCode    String // e.g., "082" for Cebu City South

  registeredAddress String  @db.Text
  zipCode           String
  contactNumber     String?

  isWithholdingAgent  Boolean @default(false)
  withholdingCategory String?

  corUrl String? // Cloud link to scanned Certificate of Registration

  @@map("bir_information")
}

// ─── Business Operations (For LGU Permits & Physical Checks) ──────
model BusinessOperations {
  id Int @id @default(autoincrement())

  clientId Int    @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tradeName String?

  // ─── Business Category & Nature ───
  industry       String? // e.g., "Retail", "Real Estate", "Professional Services"
  lineOfBusiness String? @db.Text // Specifically what they do (e.g., "IT Consulting and Software Development")
  psicCode       String? // Philippine Standard Industrial Classification Code (Crucial for BIR forms)

  businessAreaSqm Decimal? @db.Decimal(10, 2)

  // Employee Headcounts (Often required for LGU permit renewals)
  noOfManagers    Int @default(0)
  noOfSupervisors Int @default(0)
  noOfRankAndFile Int @default(0)

  // Facility Details (LGU requirements)
  noOfElevators     Int     @default(0)
  noOfEscalators    Int     @default(0)
  noOfAircons       Int     @default(0)
  hasCctv           Boolean @default(false)
  signboardLength   String?
  hasSignboardLight Boolean @default(false)

  // ─── Location Contact Info ───
  landlineNumber String?
  faxNumber      String?

  // ─── Lease / Location Compliance ───
  placeType PlaceType @default(RENTED)

  // Rented Docs
  lessorName      String?
  lessorAddress   String?  @db.Text
  monthlyRent     Decimal? @db.Decimal(15, 2)
  rentContractUrl String?
  isNotarized     Boolean  @default(false)
  hasDocStamp     Boolean  @default(false)

  // Owned Docs
  propertyOwner String?
  ownedDocsUrl  String?
  ownedReason   String? @db.Text

  // Free Use (No Rent)
  noRentReason String? @db.Text

  @@map("business_operations")
}

// ─── Corporate Details (For SEC & GIS Reporting) ──────────────────
model CorporateDetails {
  id Int @id @default(autoincrement())

  clientId Int    @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // ─── SEC Information ───
  secRegistrationNo     String?
  acronym               String?
  suffix                String? // e.g., "Inc.", "Corp.", "Ltd."
  companyClassification String? // e.g., "Stock", "Non-Stock"
  companySubclass       String?

  dateOfIncorporation DateTime? @db.Date
  termOfExistence     String?
  primaryPurpose      String?   @db.Text
  annualMeetingDate   DateTime? @db.Date

  numberOfIncorporators Int?
  hasBoardOfDirectors   Boolean @default(true)

  // ─── Capitalization ───
  authorizedCapital Decimal? @db.Decimal(15, 2)
  subscribedCapital Decimal? @db.Decimal(15, 2)
  paidUpCapital     Decimal? @db.Decimal(15, 2)

  // ─── Corporate Contact Info ───
  primaryEmail       String?
  secondaryEmail     String?
  primaryContactNo   String?
  secondaryContactNo String?

  // ─── Authorized Representative ───
  contactPerson     String? // General contact person
  authRepFirstName  String?
  authRepMiddleName String?
  authRepLastName   String?
  authRepPosition   String?
  authRepTin        String?
  authRepDob        DateTime? @db.Date

  // ─── Board of Directors / Key Officers ───
  // President
  presidentFirstName   String?
  presidentMiddleName  String?
  presidentLastName    String?
  presidentGender      String?
  presidentNationality String?
  presidentAddress     String?   @db.Text
  presidentTin         String?
  presidentEmail       String?
  presidentDob         DateTime? @db.Date

  // Treasurer
  treasurerFirstName   String?
  treasurerMiddleName  String?
  treasurerLastName    String?
  treasurerGender      String?
  treasurerNationality String?
  treasurerAddress     String?   @db.Text
  treasurerTin         String?
  treasurerEmail       String?
  treasurerDob         DateTime? @db.Date

  // Secretary
  secretaryFirstName   String?
  secretaryMiddleName  String?
  secretaryLastName    String?
  secretaryGender      String?
  secretaryNationality String?
  secretaryAddress     String?   @db.Text
  secretaryTin         String?
  secretaryEmail       String?
  secretaryDob         DateTime? @db.Date

  @@map("corporate_details")
}

// ─── Corporate Shareholder (For GIS Form Generation) ──────────────
model CorporateShareholder {
  id Int @id @default(autoincrement())

  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // ─── Shareholder Details ───
  firstName   String
  middleName  String?
  lastName    String
  dob         DateTime? @db.Date
  nationality String?
  gender      String?
  tin         String?

  // ─── Shares Info ───
  numberOfShares  Decimal @db.Decimal(15, 2)
  paidUpCapital   Decimal @db.Decimal(15, 2)
  methodOfPayment String  @default("CASH") // Matches your ENUM('Cash','Non-Cash')

  orderSequence Int @default(0)

  @@map("corporate_shareholder")
}

// ─── Individual Details (Sole Proprietors & Professionals) ────────
model IndividualDetails {
  id Int @id @default(autoincrement())

  clientId Int    @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // ─── Personal Information ───
  firstName    String
  middleName   String?
  lastName     String
  dob          DateTime @db.Date
  civilStatus  String
  gender       String
  citizenship  String   @default("Filipino")
  placeOfBirth String?

  residentialAddress String? @db.Text

  // ─── Identifications ───
  prcLicenseNo    String?
  primaryIdType   String? // e.g., "Passport", "Driver's License"
  primaryIdNumber String?

  // ─── Contact Information ───
  personalEmail   String?
  mobileNumber    String?
  telephoneNumber String?

  // ─── Parent Information (Lineage for BIR/DTI) ───
  motherFirstName  String?
  motherMiddleName String?
  motherLastName   String?

  fatherFirstName  String?
  fatherMiddleName String?
  fatherLastName   String?

  // ─── Spouse Information (For Joint Tax Filings) ───
  spouseFirstName        String?
  spouseMiddleName       String?
  spouseLastName         String?
  spouseEmploymentStatus String?
  spouseTin              String?
  spouseEmployerName     String?
  spouseEmployerTin      String?

  @@map("individual_details")
}
