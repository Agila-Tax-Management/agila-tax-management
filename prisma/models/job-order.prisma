enum JobOrderStatus {
    DRAFT // Being filled out by the Account Manager
    SUBMITTED // Sent to Operations
    ACKNOWLEDGED // Accepted by Operations Manager
    COMPLETED // All tasks finished
    CANCELLED
}

enum JobOrderItemType {
    SUBSCRIPTION
    ONE_TIME
}

/// ─── Job Order (Operations Handover Document) ─────────────────────
model JobOrder {
    id             String @id @default(cuid())
    jobOrderNumber String @unique

    leadId Int
    lead   Lead @relation(fields: [leadId], references: [id])

    clientId Int?
    client   Client? @relation(fields: [clientId], references: [id])

    date   DateTime       @default(now()) @db.Date
    status JobOrderStatus @default(DRAFT)

    notes String? @db.Text

    // ─── Document Creation ───

    // 1. Prepared By (e.g., Sales Admin)
    preparedById String?
    preparedBy   User?     @relation("JobOrderPreparer", fields: [preparedById], references: [id])
    datePrepared DateTime?

    // ─── Received and Acknowledged By ───

    // 2. Account Manager
    accountManagerId      String?
    accountManager        User?     @relation("JobOrderAccountManager", fields: [accountManagerId], references: [id])
    dateAccountManagerAck DateTime?

    // 3. Acting Operations Manager
    operationsManagerId      String?
    operationsManager        User?     @relation("JobOrderOperationsManager", fields: [operationsManagerId], references: [id])
    dateOperationsManagerAck DateTime?

    // 4. Executive
    executiveId      String?
    executive        User?     @relation("JobOrderExecutive", fields: [executiveId], references: [id])
    dateExecutiveAck DateTime?

    items JobOrderItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([leadId])
    @@index([clientId])
    @@map("job_order")
}

// ─── Job Order Line Items (The Services Table) ────────────────────
model JobOrderItem {
    id String @id @default(cuid())

    jobOrderId String
    jobOrder   JobOrder @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)

    itemType JobOrderItemType

    // Snapshot of the service name (e.g., "Agila360 - VAT" or "SEC Registration")
    serviceName String

    // The exact columns from your PDF tables
    rate     Decimal @db.Decimal(10, 2) // "Amount" or "RATE"
    discount Decimal @default(0.00) @db.Decimal(10, 2) // "Disc"
    total    Decimal @db.Decimal(10, 2) // "TOTAL"

    remarks String? @db.Text // "Remarks"

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([jobOrderId])
    @@map("job_order_item")
}
