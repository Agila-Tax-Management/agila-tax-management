// prisma/models/task.prisma

// ─── Enums ────────────────────────────────────────────────────────

enum TaskStatus {
    TODO
    IN_PROGRESS
    IN_REVIEW
    DONE
    CANCELLED
    ON_HOLD
}

enum TaskPriority {
    LOW
    NORMAL
    HIGH
    URGENT
}

// ─── Task ─────────────────────────────────────────────────────────
// Client-facing task created for compliance work

model Task {
    id Int @id @default(autoincrement())

    name        String
    description String?

    clientId Int
    client   Client @relation(fields: [clientId], references: [id])

    assignedToId Int?
    assignedTo   Employee? @relation("TaskAssignee", fields: [assignedToId], references: [id])

    dueDate DateTime?
    daysDue Int?

    status   TaskStatus   @default(TODO)
    priority TaskPriority @default(NORMAL)
    order    Int          @default(0) // for manual ordering / drag-and-drop

    subtasks      TaskSubtask[]
    conversations TaskConversation[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([clientId])
    @@index([status])
    @@map("task")
}

// ─── Task Subtask ─────────────────────────────────────────────────

model TaskSubtask {
    id Int @id @default(autoincrement())

    parentTaskId Int
    parentTask   Task @relation(fields: [parentTaskId], references: [id], onDelete: Cascade)

    name        String
    description String?

    assignedToId Int?
    assignedTo   Employee? @relation("SubtaskAssignee", fields: [assignedToId], references: [id])

    dueDate DateTime?
    daysDue Int?

    status   TaskStatus   @default(TODO)
    priority TaskPriority @default(NORMAL)
    order    Int          @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([parentTaskId])
    @@map("task_subtask")
}

// ─── Task Conversation ────────────────────────────────────────────
// Threaded comments / discussion thread on a task

model TaskConversation {
    id Int @id @default(autoincrement())

    taskId Int
    task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

    authorId String
    author   User @relation(fields: [authorId], references: [id])

    message String @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([taskId])
    @@map("task_conversation")
}

// ─── Task Template ────────────────────────────────────────────────
// Reusable task blueprints assignable to a department and linked to service plans

model TaskTemplate {
    id Int @id @default(autoincrement())

    name        String
    description String?

    // Department that owns / manages this template
    departmentId Int?
    department   Department? @relation("TaskTemplateDepartment", fields: [departmentId], references: [id])

    items TaskTemplateItem[]

    servicePlans        ServicePlan[]
    serviceOneTimePlans ServiceOneTime[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("task_template")
}

// ─── Task Template Item ───────────────────────────────────────────
// A parent-level task slot within a template

model TaskTemplateItem {
    id Int @id @default(autoincrement())

    templateId Int
    template   TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

    name        String
    description String?
    order       Int          @default(0)

    // Department responsible for completing this step
    assignedToDepartmentId Int?
    assignedToDepartment   Department? @relation("TemplateItemDepartment", fields: [assignedToDepartmentId], references: [id])

    priority TaskPriority @default(NORMAL)

    subtasks TaskTemplateSubtask[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([templateId])
    @@map("task_template_item")
}

// ─── Task Template Subtask ────────────────────────────────────────
// A subtask slot nested under a parent template item

model TaskTemplateSubtask {
    id Int @id @default(autoincrement())

    templateItemId Int
    templateItem   TaskTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Cascade)

    name        String
    description String?
    order       Int          @default(0)

    assignedToDepartmentId Int?
    assignedToDepartment   Department? @relation("TemplateSubtaskDepartment", fields: [assignedToDepartmentId], references: [id])

    priority TaskPriority @default(NORMAL)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([templateItemId])
    @@map("task_template_subtask")
}
