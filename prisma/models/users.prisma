enum Role {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

model User {
  id     String  @id @default(cuid())
  name   String
  email  String
  role   Role
  active Boolean @default(true)

  employee Employee?

  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  // ─── CRM / Account Management ───
  managedClientsAsCro Client[] @relation("ClientRelationOfficer")
  managedClientsAsOm  Client[] @relation("OperationsManager")

  assignedLeads Lead[] @relation("AssignedAgent")

  activityLogs       ActivityLog[]        @relation("InternalUserLogs")
  notifications      Notification[]       @relation("UserNotifications")
  taskConversations  TaskConversation[]
  taskHistoryLogs    TaskHistory[]
  subtaskHistoryLogs TaskSubtaskHistory[] @relation("SubtaskHistoryActor")

  leadComments    LeadComment[]
  leadHistoryLogs LeadHistory[]

  paymentsRecorded        Payment[]
  paymentHistories        PaymentHistory[]
  invoiceHistoryLogs      InvoiceHistory[]
  subscriptionHistoryLogs SubscriptionHistory[]
  cashAdvancesApproved    CashAdvance[]         @relation("CashAdvanceApprover")

  approvedOvertimes OvertimeRequest[] @relation("OvertimeApprover")
  approvedLeaves    LeaveRequest[]    @relation("LeaveApprover")
  approvedCoas      CoaRequest[]      @relation("CoaApprover")

  payslipsPrepared     Payslip[] @relation("PayslipPreparer")
  payslipsApproved     Payslip[] @relation("PayslipApprover")
  acknowledgedPayslips Payslip[] @relation("PayslipAcknowledger")

  // ─── Job Order Workflows ───
  preparedJobOrders JobOrder[] @relation("JobOrderPreparer")

  assignedJoAccountManagers JobOrder[] @relation("JoAssignedAccountManager")
  actualJoAccountManagers   JobOrder[] @relation("JoActualAccountManager")

  assignedJoOperationsManagers JobOrder[] @relation("JoAssignedOperationsManager")
  actualJoOperationsManagers   JobOrder[] @relation("JoActualOperationsManager")

  assignedJoExecutives JobOrder[] @relation("JoAssignedExecutive")
  actualJoExecutives   JobOrder[] @relation("JoActualExecutive")

  // ─── Compliance Defaults (From ClientCompliance) ───
  defaultProcessorFor        ClientCompliance[] @relation("DefaultProcessor")
  defaultVerifierFor         ClientCompliance[] @relation("DefaultVerifier")
  defaultPaymentProcessorFor ClientCompliance[] @relation("DefaultPaymentProcessor")
  defaultPaymentApproverFor  ClientCompliance[] @relation("DefaultPaymentApprover")
  defaultFinalApproverFor    ClientCompliance[] @relation("DefaultFinalApprover")
  defaultSalesOfficerFor     ClientCompliance[] @relation("DefaultSalesOfficer")

 // ─── Compliance Actual Executions & Overrides ───
  assignedProcessors         ComplianceRecord[] @relation("RecordAssignedProcessor")
  actualProcessors           ComplianceRecord[] @relation("RecordActualProcessor")
  
  assignedVerifiers          ComplianceRecord[] @relation("RecordAssignedVerifier")
  actualVerifiers            ComplianceRecord[] @relation("RecordActualVerifier")
  
  assignedPaymentProcessors  ComplianceRecord[] @relation("RecordAssignedPayProcessor")
  actualPaymentProcessors    ComplianceRecord[] @relation("RecordActualPayProcessor")
  
  assignedPaymentApprovers   ComplianceRecord[] @relation("RecordAssignedPayApprover")
  actualPaymentApprovers     ComplianceRecord[] @relation("RecordActualPayApprover")
  
  assignedFinalApprovers     ComplianceRecord[] @relation("RecordAssignedFinalApprover")
  actualFinalApprovers       ComplianceRecord[] @relation("RecordActualFinalApprover")
  
  salesObservedRecords       ComplianceRecord[] @relation("RecordSalesOfficer")

  // ─── Global Compliance Defaults (From ComplianceSetting) ───
    defaultClientProcessors        ComplianceSetting[] @relation("DefaultClientProcessor")
    defaultClientVerifiers         ComplianceSetting[] @relation("DefaultClientVerifier")
    defaultClientPayProcessors     ComplianceSetting[] @relation("DefaultClientPayProcessor")
    defaultClientPayApprovers      ComplianceSetting[] @relation("DefaultClientPayApprover")
    defaultClientFinalApprovers    ComplianceSetting[] @relation("DefaultClientFinalApprover")
    defaultClientSalesOfficers     ComplianceSetting[] @relation("DefaultClientSalesOfficer")

  // ─── TSA Workflows ───
  preparedTsas         TsaContract[] @relation("TsaPreparer")
  assignedTsaApprovals TsaContract[] @relation("TsaAssignedApprover")
  actuallyApprovedTsas TsaContract[] @relation("TsaActualApprover")

  // ─── Sales Portal Defaults (From SalesSetting) ───
  defaultJoProcessApprovals    SalesSetting[] @relation("DefaultJoProcessApprover")
  defaultJoOperationsApprovals SalesSetting[] @relation("DefaultJoOperationsApprover")
  defaultJoAccountApprovals    SalesSetting[] @relation("DefaultJoAccountApprover")
  defaultJoGeneralApprovals    SalesSetting[] @relation("DefaultJoGeneralApprover")
  defaultTsaApprovals          SalesSetting[] @relation("DefaultTsaApprover")

  // ─── Communication ───
  complianceNotes           ComplianceNote[]
  ewtItemHistories          EwtItemHistory[]
  ewtItemTemplateHistories  EwtItemTemplateHistory[]

  // ─── Petty Cash & Client Funds ───
  pettyCashRequests               PettyCash[]             @relation("PettyCashRequester")
  pettyCashCustodianApprovals     PettyCash[]             @relation("PettyCashCustodian")
  pettyCashManagerApprovals       PettyCash[]             @relation("PettyCashAccountingManager")
  clientFundTransactionsProcessed ClientFundTransaction[] @relation("ClientFundProcessor")

  @@index([role])
  @@index([active])
  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
